{
  "name": "wake-on-lan",
  "version": "0.0.2",
  "description": "Wake on LAN Desktop App",
  "main": "dist/main/main.js",
  "author": "Matus Cvengros",
  "license": "MIT",
  "scripts": {
    "copy-assets": "node scripts/copy-assets.js",
    "clean": "node -e \"const fs=require('fs');['dist','release','node_modules'].forEach(d=>{fs.rmSync(d,{recursive:true,force:true,maxRetries:3,retryDelay:100})})\"",
    "build": "tsc && npm run copy-assets",
    "dev": "npm run build && electron .",
    "package": "npm run build && electron-builder",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.3"
  }
}
