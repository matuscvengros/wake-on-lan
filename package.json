{
  "name": "wake-on-lan",
  "version": "0.0.1",
  "description": "Wake-on-LAN desktop app",
  "main": "dist/main/main.js",
  "author": "Matus Cvengros",
  "license": "MIT",
  "scripts": {
    "copy-assets": "node -e \"require('fs').copyFileSync('src/renderer/index.html','dist/renderer/index.html');require('fs').copyFileSync('src/renderer/styles.css','dist/renderer/styles.css')\"",
    "clean": "node -e \"const fs=require('fs');['dist','release','node_modules'].forEach(d=>{fs.rmSync(d,{recursive:true,force:true})})\"",
    "build": "tsc && npm run copy-assets",
    "dev": "npm run build && electron .",
    "package": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.0"
  }
}
